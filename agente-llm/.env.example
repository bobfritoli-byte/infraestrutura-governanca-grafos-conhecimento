# =============================================================================
# Configuração do Agente Conversacional — Arquitetura de Referência
# Copie este arquivo para ".env" e preencha com suas próprias credenciais.
# Nunca commite o arquivo ".env" preenchido.
# =============================================================================

# Provedor de LLM padrão: "anthropic" (Haiku, nuvem), "groq" (nuvem) ou "ollama" (local).
# A interface permite alternar por consulta; este é apenas o padrão.
LLM_PROVIDER=anthropic

# --- Anthropic (Claude Haiku — barato, rápido e preciso) ---
# Gere sua chave em https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Groq (nuvem, alternativa) ---
# Gere sua chave em https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (local, alternativa sem custo de API) ---
OLLAMA_URL=http://localhost:11434
# Modelo local para gerar SPARQL.
# Modelos muito pequenos (ex: gemma3:1b) tendem a gerar prefixos SPARQL incorretos.
OLLAMA_MODEL=gemma3:4b

# --- GraphDB (endpoint SPARQL do triplestore) ---
# URL do seu repositório GraphDB (ajuste para o seu ambiente).
ELLAS_GRAPH_URL=https://app.ellas.ufmt.br/repositories/EllasV2
# Credenciais do usuário com acesso de leitura ao repositório. Obrigatórias —
# não há valor padrão por questões de segurança.
ELLAS_GRAPH_USER=
ELLAS_GRAPH_PASS=
