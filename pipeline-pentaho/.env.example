# Copie este arquivo para ".env" e preencha com suas próprias credenciais.
# Nunca commite o arquivo ".env" preenchido.

# URL do repositório GraphDB (ajuste para o seu ambiente).
ELLAS_GRAPH_URL=https://app.ellas.ufmt.br/repositories/EllasV2

# Credenciais do usuário com acesso de escrita ao repositório (necessário
# para gravar as triplas). Obrigatórias — não há valor padrão por questões
# de segurança.
ELLAS_GRAPH_USER=
ELLAS_GRAPH_PASS=

# Caminho local do arquivo .ttl gerado pelo GerarRDF.bat (opcional, usa
# ./Triplification.ttl por padrão).
RDF_FILE_PATH=
